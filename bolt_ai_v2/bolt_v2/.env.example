# Bolt AI — Environment Variables
# Copy: cp .env.example .env   then fill in real values
# NEVER commit .env to git

# ── AI (Required for script generation) ──────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Voice (edge-tts is completely free — no key needed) ──
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=your-voice-id
GOOGLE_CLOUD_TTS_KEY=your-gcp-key

# ── Avatar Video ─────────────────────────────────────────
VIDNOZ_API_KEY=your-vidnoz-key
VIDNOZ_AVATAR_ID=your-avatar-id
DID_API_KEY=your-did-key
DID_PRESENTER_URL=https://your-avatar-image.jpg

# ── Publishing ────────────────────────────────────────────
BUFFER_ACCESS_TOKEN=your-buffer-token
YOUTUBE_CLIENT_ID=your-yt-client-id
YOUTUBE_CLIENT_SECRET=your-yt-secret
YOUTUBE_REFRESH_TOKEN=your-yt-refresh
TIKTOK_ACCESS_TOKEN=your-tiktok-token
INSTAGRAM_ACCESS_TOKEN=your-ig-token
INSTAGRAM_USER_ID=your-ig-user-id

# ── Notifications ─────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
EMAIL_USERNAME=your@gmail.com
EMAIL_PASSWORD=your-app-password

# ── API Authentication ────────────────────────────────────
# Set a secret key to protect API endpoints. Leave empty to disable auth (local dev).
# BOLT_API_KEY=your-secret-api-key-here

# ── CORS (comma-separated allowed origins for the API) ────
BOLT_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Backup base path (auto-detected if not set) ──────────
# BOLT_BASE_PATH=/app
